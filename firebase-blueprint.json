{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A website project generated by AI",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique project ID" },
        "userId": { "type": "string", "description": "Owner user ID" },
        "name": { "type": "string", "description": "Project name" },
        "prompt": { "type": "string", "description": "AI prompt used" },
        "content": { "type": "object", "description": "Generated site content" },
        "settings": { "type": "object", "description": "Project settings" },
        "publishUrl": { "type": "string", "description": "Public URL if published" },
        "isPublished": { "type": "boolean", "description": "Whether the site is published" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "content"]
    },
    "UserUsage": {
      "title": "UserUsage",
      "description": "Tracks user usage and plan",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro"] },
        "generationsCount": { "type": "integer" },
        "lastGenerationReset": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    }
  },
  "database": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User projects"
    },
    "/users/{userId}": {
      "schema": "UserUsage",
      "description": "User usage tracking"
    }
  }
}
